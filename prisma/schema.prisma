// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Wheel {
  id          String   @id @default(uuid())
  shop        String
  title       String
  isActive    Boolean  @default(false)
  config      String   @default("{}") // JSON string for design settings (colors, triggers, etc.)
  segments    Segment[]
  spins       Spin[]
  impressions Impression[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Segment {
  id          String   @id @default(uuid())
  wheelId     String
  wheel       Wheel    @relation(fields: [wheelId], references: [id], onDelete: Cascade)
  label       String
  value       String   // Prize or Coupon code
  probability Float    // 0 to 100
  color       String?  // Optional custom segment color
}

model Spin {
  id          String   @id @default(uuid())
  wheelId     String
  wheel       Wheel    @relation(fields: [wheelId], references: [id], onDelete: Cascade)
  customerId  String?  // Optional Shopify customer ID
  customerEmail String?
  result      String   // Segment label or value won
  couponCode  String?
  createdAt   DateTime @default(now())
}

model Impression {
  id          String   @id @default(uuid())
  wheelId     String
  wheel       Wheel    @relation(fields: [wheelId], references: [id], onDelete: Cascade)
  shop        String
  createdAt   DateTime @default(now())
}

model CustomCode {
  id   String @id @default(uuid())
  shop String @unique
  code String @default("")
}

model EmailSettings {
  id             String   @id @default(uuid())
  shop           String   @unique
  enabled        Boolean  @default(false)
  fromEmail      String   @default("")
  fromName       String   @default("Luckivo Spin Wheel")
  subject        String   @default("🎁 Your discount code is here!")
  headerTitle    String   @default("You Won!")
  headerSubtitle String   @default("Congratulations on your lucky spin")
  headerEmoji    String   @default("🎡")
  brandColor     String   @default("#6c5ce7")
  ctaText        String   @default("")
  ctaUrl         String   @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
