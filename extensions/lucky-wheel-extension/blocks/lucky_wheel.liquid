<link rel="stylesheet" href="{{ 'lucky_wheel.css' | asset_url }}">
<script src="{{ 'lucky_wheel.js' | asset_url }}" defer="defer"></script>

<div id="lucky-wheel-root" 
     class="lucky-wheel-container"
     data-proxy-url="/apps/wheel-proxy">
  
  <div class="lucky-wheel-overlay" id="lucky-wheel-overlay" style="display: none;">
    <div class="lucky-wheel-modal">
      <button class="lucky-wheel-close" id="lucky-wheel-close">&times;</button>
      
      <div class="lucky-wheel-content">
        <div class="wheel-wrapper">
          <canvas id="wheel-canvas" width="400" height="400"></canvas>
          <div class="lucky-wheel-center-logo" id="lucky-wheel-center-logo" style="display: none;">
            <img id="lucky-wheel-center-logo-img" alt="Center logo">
          </div>
          <div class="wheel-pointer" aria-hidden="true">
            <svg width="44" height="30" viewBox="0 0 44 30" fill="none">
              <path
                d="M2 15L18 4.5V25.5L2 15Z"
                fill="#ffffff"
                stroke="#f1ad46"
                stroke-width="3"
                stroke-linejoin="round"
              />
              <circle cx="30" cy="15" r="10" fill="#ffffff" stroke="#f1ad46" stroke-width="4" />
              <circle cx="30" cy="15" r="3.4" fill="#f1ad46" />
            </svg>
          </div>
        </div>

        <div class="lucky-wheel-panel">
          <div class="lucky-wheel-top-logo" id="lucky-wheel-top-logo" style="display: none;">
            <img id="lucky-wheel-top-logo-img" alt="Wheel logo">
          </div>

          <h2 id="lucky-wheel-title">Spin to Win!</h2>
          <p id="lucky-wheel-description">Try your luck and win amazing prizes!</p>

          <div class="lucky-wheel-form" id="lucky-wheel-form">
            <input type="text" id="lucky-wheel-name" placeholder="Enter your name">
            <input type="email" id="lucky-wheel-email" placeholder="Enter your email" required>
            <input type="tel" id="lucky-wheel-phone" placeholder="Enter your phone number">
            <label class="lucky-wheel-consent" id="lucky-wheel-consent-row">
              <input type="checkbox" id="lucky-wheel-consent-checkbox">
              <span>I agree to receive updates and offers from this store.</span>
            </label>
            <button type="button" id="lucky-wheel-spin-btn">SPIN NOW</button>
            <p class="lucky-wheel-error" id="lucky-wheel-error" style="display: none;"></p>
            <p id="lucky-wheel-info-text">By entering, you agree to receive updates and offers from our store.</p>
          </div>

          <div id="lucky-wheel-result" style="display: none;">
            <h3 id="lucky-wheel-result-heading">🎁 You Won!</h3>
            <p id="lucky-wheel-result-description">Copy your code and enjoy your reward at checkout.</p>
            <p id="lucky-wheel-result-email-sent">Check your email for your discount code!</p>
            <p id="lucky-wheel-result-reward"></p>
            <div id="lucky-wheel-code-row" class="lucky-wheel-code-row">
              <span id="lucky-wheel-coupon">CODE123</span>
              <button type="button" id="lucky-wheel-copy-btn">Copy Code</button>
            </div>
            <button type="button" id="lucky-wheel-continue-btn">Continue Shopping</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Luckivo - Spin Wheel",
  "target": "body",
  "settings": [
    {
      "type": "color",
      "id": "primary_color",
      "label": "Primary Color",
      "default": "#4f46e5"
    }
  ]
}
{% endschema %}
